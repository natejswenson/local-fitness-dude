# local-fitness environment overrides.
#
# Copy this file to `.env` (in the project root) and fill in the values
# you actually need. `.env` is gitignored. The CLI auto-loads it at
# startup. Real shell-set vars take precedence — useful when running in
# Docker (compose injects vars; .env is ignored inside the image).
#
# Every variable below is OPTIONAL. Defaults work for the host CLI on
# macOS with Garmin creds in the Keychain.

# --- Garmin Connect ---------------------------------------------------
# When BOTH are set, env wins over the macOS Keychain (host CLI default).
# Required for container deployments — Linux containers can't reach the
# host's Keychain. Leave unset on a Mac and use `fitness setup` instead.
# GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-garmin-password
#
# Where garminconnect/garth caches its login tokens. Read by the garth
# library (not this app's code). The default location works on the host CLI;
# containers set it to a bind-mounted path so tokens survive rebuilds (see
# docs/deployment.md).
# GARMINTOKENS=/home/app/.garminconnect/garmin_tokens.json

# --- Paths ------------------------------------------------------------
# Defaults are project-relative: ./data, ./briefings, ./data/user_notes.md.
# Override only if you bind-mount volumes (containers) or want the data
# to live elsewhere. Ignored on the host CLI when unset.
# LOCAL_FITNESS_DATA_DIR=/data
# LOCAL_FITNESS_BRIEFINGS_DIR=/briefings
# LOCAL_FITNESS_NOTES_PATH=/data/user_notes.md

# --- Web server -------------------------------------------------------
# `fitness serve` defaults to 127.0.0.1 (localhost-only). Set to 0.0.0.0
# inside a container so Docker port-forwarding can reach it.
# LOCAL_FITNESS_HOST=0.0.0.0

# --- Display units ----------------------------------------------------
# Runner-facing distances/pace render in miles by default (mi, min/mi).
# Raw values (meters, sec/km) are always present in tool output; setting
# this to anything other than "miles" just suppresses the *_mi convenience
# fields. Default is "miles".
# LOCAL_FITNESS_DISPLAY_UNITS=miles

# --- Brief reasoning effort (speed/quality lever) ---------------------
# Reasoning effort for the daily-brief composer: low | medium | high | max.
# Measured 2026-06-20: the brief's wall-clock is dominated by extended
# thinking; "low" cut a ~230s brief to ~82s while a blind A/B judge rated
# its content as good or better. Default is "low". Raise it if you want the
# model to deliberate more (slower). (The SDK's thinking budget_tokens knob
# is ignored on the Claude Code CLI path — effort is the working lever.)
# LOCAL_FITNESS_BRIEF_EFFORT=low

# --- Claude credentials (scheduled brief job) -------------------------
# The daily `fitness brief` job (and scripts/ab_brief.py) compose the
# brief via the Claude-bound headless agent, which authenticates with your
# Claude Max subscription token — no per-token API billing. The web server
# itself runs NO Claude inference, so it does NOT need this; only the
# scheduled composer does. The CLI auto-loads it from this .env, including
# under the minimal launchd environment (see ops/).
#
# Get it with the Claude Code CLI:  claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=paste-your-claude-oauth-token-here

# --- API auth ---------------------------------------------------------
# Bearer token gating /api/* endpoints. Without it set, /api/* exposes
# all wellness data unauthenticated. The server REFUSES to start on a
# non-loopback host without this set — loopback (127.0.0.1) keeps working
# without it for host-CLI dev convenience.
#
# Generate a fresh token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Then paste into the SPA login screen on first load (per device); the
# browser remembers it via localStorage.
# LOCAL_FITNESS_API_TOKEN=paste-the-generated-token-here

# --- MCP server (interactive Claude access to your fitness data) ----------
# The /mcp/ endpoint exposes the fitness tools to your Claude Code / Desktop
# sessions over streamable-HTTP, behind LOCAL_FITNESS_API_TOKEN. The MCP
# transport's DNS-rebinding guard rejects any Host not in this allowlist
# (returns 421), so it MUST include the host you serve at. Comma-separated.
# Default (works for a fresh clone on loopback): 127.0.0.1,localhost
# Add any non-loopback host you serve at, e.g. an internal hostname behind a
# reverse proxy (fitness.home.local below is just an EXAMPLE override, not a
# default).
# LOCAL_FITNESS_MCP_ALLOWED_HOSTS=fitness.home.local,127.0.0.1,localhost

# --- Grading / projection behavior (coaching preferences) ----------------
# How the training plan is graded and projected. Every default equals the
# historical hardcoded value, so a fresh clone behaves identically. These can
# also be set live (no restart) in the SQLite settings table via
#   uv run fitness config set <key> <value>
# When both are set, the DB value (config set) overrides the env var here.
#
# Do recovery WALKS satisfy an easy/recovery prescription? (long/tempo/
# interval/race always require running.) Default true.
# LOCAL_FITNESS_COUNT_WALKS_EASY=true
#
# Include walking distance in the weekly-mileage rollup? Default false
# (weekly mileage is a running-volume metric).
# LOCAL_FITNESS_COUNT_WALKS_MILEAGE=false
#
# Grade-band fractions: actual/target >= done => "done"; >= partial =>
# "partial"; below => "missed". Must satisfy 0 <= partial <= done <= 1, else
# BOTH revert to defaults. Defaults 0.80 / 0.40.
# LOCAL_FITNESS_GRADE_DONE_FRACTION=0.80
# LOCAL_FITNESS_GRADE_PARTIAL_FRACTION=0.40
#
# Lookback window (days) for the "best recent effort" that drives the
# projected finish. Clamped to [1, 3650]; nonsense values fall back. Default 120.
# LOCAL_FITNESS_RIEGEL_LOOKBACK_DAYS=120

# --- Coach tone profile (how the brief talks) ----------------------------
# Selectable coaching voice. One of: adaptive (default — today's behavior),
# supportive (upbeat), neutral (factual), hardass (relentless). Settable live
# via `uv run fitness config set coach_profile <name>`; a DB value overrides
# this env var.
# LOCAL_FITNESS_COACH_PROFILE=adaptive
#
# Per-dial overrides (default = the selected profile's own value). These are
# GLOBAL — they apply to whichever profile is selected, so unset one when
# switching profiles if you want the new profile's native value. Dials clamp to
# 0-10; thresholds to 0.0-1.20.
# LOCAL_FITNESS_COACH_HARSHNESS=6
# LOCAL_FITNESS_COACH_WARMTH=6
# LOCAL_FITNESS_COACH_PUSH=7
# LOCAL_FITNESS_COACH_ROAST_THRESHOLD=0.85
# LOCAL_FITNESS_COACH_PRAISE_THRESHOLD=0.95
