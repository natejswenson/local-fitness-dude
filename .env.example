# local-fitness environment overrides.
#
# Copy this file to `.env` (in the project root) and fill in the values
# you actually need. `.env` is gitignored. The CLI auto-loads it at
# startup. Real shell-set vars take precedence — useful when running in
# Docker (compose injects vars; .env is ignored inside the image).
#
# Every variable below is OPTIONAL. Defaults work for the host CLI on
# macOS with Garmin creds in the Keychain.

# --- Garmin Connect ---------------------------------------------------
# When BOTH are set, env wins over the macOS Keychain (host CLI default).
# Required for container deployments — Linux containers can't reach the
# host's Keychain. Leave unset on a Mac and use `fitness setup` instead.
# GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-garmin-password

# --- Paths ------------------------------------------------------------
# Defaults are project-relative: ./data, ./briefings, ./data/user_notes.md.
# Override only if you bind-mount volumes (containers) or want the data
# to live elsewhere. Ignored on the host CLI when unset.
# LOCAL_FITNESS_DATA_DIR=/data
# LOCAL_FITNESS_BRIEFINGS_DIR=/briefings
# LOCAL_FITNESS_NOTES_PATH=/data/user_notes.md

# --- Web server -------------------------------------------------------
# `fitness serve` defaults to 127.0.0.1 (localhost-only). Set to 0.0.0.0
# inside a container so Docker port-forwarding can reach it.
# LOCAL_FITNESS_HOST=0.0.0.0
