# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual envs
.venv

# Project data — never commit personal health data or generated briefings
data/
briefings/
logs/

# Local secrets / env-specific config (Garmin creds, paths, host overrides)
.env
.env.local

# Rendered launchd plist (install-launchd.sh substitutes host paths into
# the .template — the rendered output is host-specific, not portable)
ops/*.plist.rendered
ops/com.local-fitness.daily.plist

# Frontend (web/)
web/node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code local runtime state
.claude/

# uxpolish-generated variant files (one-shot, not committed)
web/src/components/*.v[0-9].tsx
